# ----------------------------------------------------------------------------
# MMR — environment configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the real values.
# Never commit a populated .env — it is gitignored.

# ---- LLM provider --------------------------------------------------------
# `groq` for production usage, `stub` for deterministic tests / CI.
LLM_PROVIDER=groq

# Groq model identifier (kept as a variable to make swaps explicit).
LLM_MODEL=llama-3.3-70b-versatile

# Groq API key — required when LLM_PROVIDER=groq.
GROQ_API_KEY=

# ---- Speech-to-text ------------------------------------------------------
# AssemblyAI API key — required for diarised utterance transcription.
ASSEMBLYAI_API_KEY=

# ---- Agent orchestration --------------------------------------------------
# Bounded concurrency for parallel agent calls per analysis window.
AGENT_MAX_CONCURRENCY=4

# ---- Backend --------------------------------------------------------------
# Maximum upload size for /api/jobs (MB). Larger uploads return 413.
MAX_UPLOAD_MB=500

# Optional: override the SQLite job-metadata DB location.
# Default: data/mmr.db (relative to repo root)
# MMR_DB_URL=sqlite:///./data/mmr.db

# ---- Frontend (build-time) -----------------------------------------------
# Base URL the React app uses to reach the backend.
# In docker-compose this becomes http://backend:8000 ; in dev, http://localhost:8000.
VITE_API_BASE_URL=http://localhost:8000
