# Copy to `.env` and fill in. The backend loads via pydantic-settings.

# === LLM ===
# Provider: "groq"/"google-gla" for real calls, "stub" for tests / local dev.
# The concrete provider is derived from the LLM_MODEL prefix.
LLM_PROVIDER=google-gla
LLM_MODEL=google-gla:gemini-2.5-flash
GROQ_API_KEY=
# Server-wide Gemini key. Leave blank for a BYOK deployment where each user
# supplies their own key in the upload form (the request key wins; this is the
# fallback for self-hosting).
GEMINI_API_KEY=

# === Transcription ===
# Same BYOK rule: blank = users supply their own AssemblyAI key per request.
ASSEMBLYAI_API_KEY=

# === Observability (optional) ===
# Set to send pydantic-ai traces + token usage to Logfire. Blank = no-op.
LOGFIRE_TOKEN=

# === Agents ===
AGENT_MAX_CONCURRENCY=4

# === Pipeline (paths to system models) ===
FACE_LANDMARKER_PATH=models/face_landmarker.task
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
SPEAKER_LABEL=B

# === Backend ===
DATA_ROOT=data
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
DB_PATH=data/mmr.db
MAX_UPLOAD_MB=500
APP_NAME=MMR
APP_VERSION=0.1.0
# CORS (comma-separated); the default covers Vite dev (5173)
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# === Test mode ===
# When 1, allows uploading a pre-computed master parquet instead of a video.
# Used in CI / integration tests only.
MMR_TEST_MODE=0

# === Frontend ===
# Vite reads VITE_-prefixed vars; defined here for documentation.
VITE_API_BASE_URL=http://localhost:8000
