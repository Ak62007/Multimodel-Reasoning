# ----------------------------------------------------------------------------
# MMR — environment configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the real values.
# Never commit a populated .env — it is gitignored.

# ---- LLM provider --------------------------------------------------------
# `groq` for production usage, `stub` for deterministic tests / CI.
LLM_PROVIDER=groq

# Model identifier. Two accepted shapes:
#   1. Bare model id, e.g. `llama-3.3-70b-versatile`. Treated as Groq.
#   2. Provider-qualified, e.g. `openai:gpt-4o-mini`,
#      `anthropic:claude-haiku-4-5`, `google-gla:gemini-1.5-flash`,
#      `groq:llama-3.1-8b-instant`. Sent verbatim to pydantic-ai.
# Set the matching API key env var below.
LLM_MODEL=llama-3.3-70b-versatile

# Groq API key — required when LLM_MODEL targets Groq.
GROQ_API_KEY=

# OpenAI API key — required when LLM_MODEL starts with `openai:`.
# OPENAI_API_KEY=

# Anthropic API key — required when LLM_MODEL starts with `anthropic:`.
# ANTHROPIC_API_KEY=

# Google Generative Language (Gemini) key — required when LLM_MODEL
# starts with `google-gla:`.
# GEMINI_API_KEY=

# ---- Speech-to-text ------------------------------------------------------
# AssemblyAI API key — required for diarised utterance transcription.
ASSEMBLYAI_API_KEY=

# ---- Agent orchestration --------------------------------------------------
# Bounded concurrency for parallel agent calls per analysis window.
AGENT_MAX_CONCURRENCY=4

# ---- Backend --------------------------------------------------------------
# Maximum upload size for /api/jobs (MB). Larger uploads return 413.
MAX_UPLOAD_MB=500

# Optional: override the SQLite job-metadata DB location.
# Default: data/mmr.db (relative to repo root)
# MMR_DB_URL=sqlite:///./data/mmr.db

# ---- Frontend (build-time) -----------------------------------------------
# Base URL the React app uses to reach the backend.
# In docker-compose this becomes http://backend:8000 ; in dev, http://localhost:8000.
VITE_API_BASE_URL=http://localhost:8000
