# Copy to `.env` and fill in. The backend loads via pydantic-settings.

# === LLM ===
# Provider: "groq" for real calls, "stub" for tests / local dev without keys
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# === Transcription ===
ASSEMBLYAI_API_KEY=

# === Agents ===
AGENT_MAX_CONCURRENCY=4

# === Backend ===
DATA_ROOT=data
MAX_UPLOAD_MB=500
APP_NAME=MMR

# === Test mode ===
# When 1, allows uploading a pre-computed master parquet instead of a video.
# Used in CI / integration tests only.
MMR_TEST_MODE=0

# === Frontend ===
# Vite reads VITE_-prefixed vars; defined here for documentation.
VITE_API_BASE_URL=http://localhost:8000
