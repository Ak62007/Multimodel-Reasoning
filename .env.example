# Copy to `.env` and fill in. The backend loads via pydantic-settings.

# === LLM ===
# Provider: "groq" for real calls, "stub" for tests / local dev without keys
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# === Transcription ===
ASSEMBLYAI_API_KEY=

# === Agents ===
AGENT_MAX_CONCURRENCY=4

# === Pipeline (paths to system models) ===
FACE_LANDMARKER_PATH=models/face_landmarker.task
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
SPEAKER_LABEL=B

# === Backend ===
DATA_ROOT=data
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
DB_PATH=data/mmr.db
MAX_UPLOAD_MB=500
APP_NAME=MMR
APP_VERSION=0.1.0
# CORS (comma-separated); the default covers Vite dev (5173)
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# === Test mode ===
# When 1, allows uploading a pre-computed master parquet instead of a video.
# Used in CI / integration tests only.
MMR_TEST_MODE=0

# === Frontend ===
# Vite reads VITE_-prefixed vars; defined here for documentation.
VITE_API_BASE_URL=http://localhost:8000
